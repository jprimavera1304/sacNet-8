<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github-oakisland" value="https://nuget.pkg.github.com/OakIsland22/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-oakisland">
      <package pattern="Shared.Backend.Core" />
    </packageSource>
  </packageSourceMapping>
</configuration>
